  </div>
</section>

<section id="spacing">
  <div class="container">
    <div class="eyebrow">Spacing</div>
    <h2>Spacing &amp; Layout</h2>

    <h3>Container Widths</h3>
    <table class="spec-table">
      <thead>
        <tr><th>Context</th><th>Max Width</th><th>Horizontal Padding</th></tr>
      </thead>
      <tbody>
        <tr><td>Default</td><td><code>1100px</code></td><td><code>40px</code></td></tr>
        <tr><td>Narrow (documents)</td><td><code>620–900px</code></td><td><code>40px</code></td></tr>
        <tr><td>Tablet (≤768px)</td><td>fluid</td><td><code>24px</code></td></tr>
        <tr><td>Mobile (≤480px)</td><td>fluid</td><td><code>16px</code></td></tr>
      </tbody>
    </table>

    <h3>Border Radius</h3>
    <table class="spec-table">
      <thead>
        <tr><th>Element</th><th>Radius</th></tr>
      </thead>
      <tbody>
        <tr><td>Cards, wrappers</td><td><code>12px</code></td></tr>
        <tr><td>Buttons</td><td><code>8px</code> (web), <code>6px</code> (email)</td></tr>
        <tr><td>Badges / tags</td><td><code>4px</code></td></tr>
        <tr><td>Code blocks</td><td><code>6px</code></td></tr>
      </tbody>
    </table>
  </div>
</section>

<script>
(function () {
  var root = document.querySelector(".logo-picker");
  var dataEl = document.getElementById("logoData");
  if (!root || !dataEl) return;

  var variants = JSON.parse(dataEl.textContent);
  var base = root.getAttribute("data-asset-base") || "/assets/";

  // Index by mark|surface|frame for O(1) lookup.
  var index = {};
  variants.forEach(function (v) { index[v.mark + "|" + v.surface + "|" + v.frame] = v; });

  // Initial state from the default variant.
  var def = variants.find(function (v) { return v.name === root.getAttribute("data-default"); }) || variants[0];
  var state = { mark: def.mark, surface: def.surface, frame: def.frame };

  var img = document.getElementById("logoStageImg");
  var canvas = document.getElementById("logoStageCanvas");
  var caption = document.getElementById("logoStageCaption");
  var aspect = document.getElementById("logoStageAspect");
  var svgLink = document.getElementById("logoStageSvg");
  var pngWrap = document.getElementById("logoStagePngs");

  function gcd(a, b) { return b ? gcd(b, a % b) : a; }
  function ratio(w, h) {
    var g = gcd(w, h) || 1;
    var rw = Math.round((w / g) * 10) / 10, rh = Math.round((h / g) * 10) / 10;
    // Normalise to a readable "x : 1" when not a clean small integer ratio.
    if (rw > 12 || rh > 12) return (Math.round((w / h) * 100) / 100) + " : 1";
    return rw + " : " + rh;
  }

  function render() {
    var v = index[state.mark + "|" + state.surface + "|" + state.frame];
    if (!v) return;

    img.src = base + "logos/" + v.svg;
    img.alt = v.caption;

    // Surface backdrop: neutral for solid (the SVG carries its own background,
    // so its footprint reads against it); a contrasting checkerboard for
    // transparent — dark behind light ink, light behind dark ink.
    canvas.classList.remove("checker-light", "checker-dark");
    if (v.checker) canvas.classList.add("checker-" + v.checker);

    caption.textContent = v.caption;
    aspect.textContent = (v.frame === "square" ? "Square · 1 : 1" : "Aspect " + ratio(v.w, v.h)) + " · scalable SVG";

    svgLink.href = base + "logos/" + v.svg;
    svgLink.setAttribute("download", "");

    pngWrap.innerHTML = "";
    (v.pngs || []).forEach(function (png) {
      var m = png.match(/-(\d+)\.png$/);
      if (!m) return;
      var a = document.createElement("a");
      a.href = base + "raster/" + png;
      a.textContent = m[1] + "px";
      a.setAttribute("download", "");
      pngWrap.appendChild(a);
    });

    // Sync active states.
    root.querySelectorAll(".logo-toggle").forEach(function (btn) {
      btn.classList.toggle("active", state[btn.getAttribute("data-axis")] === btn.getAttribute("data-value"));
    });
  }

  root.addEventListener("click", function (e) {
    var btn = e.target.closest(".logo-toggle");
    if (!btn) return;
    state[btn.getAttribute("data-axis")] = btn.getAttribute("data-value");
    render();
  });

  render();
})();
</script>
