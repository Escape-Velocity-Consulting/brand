<div class="identity-anchors">
  <a href="#logos">Logos</a>
  <a href="#colors">Colors</a>
  <a href="#typography">Typography</a>
  <a href="#spacing">Spacing</a>
</div>

<section id="logos">
  <div class="container">
    <div class="eyebrow">Logos</div>
    <h2>Logo Variants</h2>
    <p class="section-intro">Every logo is one combination of three choices: the <strong>mark</strong> (how the wordmark is composed), the <strong>frame</strong> (canvas shape &amp; padding), and the <strong>surface</strong> (background &amp; ink). Pick a combination below to preview and download it, or open the full gallery to scan all {{ logos.count }} variants. SVGs are outlined — they render without the font installed.</p>

    {# Variant data + asset base for the picker JS #}
    <script type="application/json" id="logoData">{{ logos.variants | dump | safe }}</script>

    <div class="logo-picker"
         data-asset-base="{{ '/assets/' | url }}"
         data-default="{{ logos.default }}">
      <div class="logo-picker-controls">
        <div class="logo-axis" data-axis="mark">
          <span class="logo-axis-label">Mark</span>
          <div class="logo-axis-options">
            {% for m in logos.marks %}<button type="button" class="logo-toggle" data-axis="mark" data-value="{{ m.key }}">{{ m.label }}</button>{% endfor %}
          </div>
        </div>
        <div class="logo-axis" data-axis="frame">
          <span class="logo-axis-label">Frame</span>
          <div class="logo-axis-options">
            {% for f in logos.frames %}<button type="button" class="logo-toggle" data-axis="frame" data-value="{{ f.key }}">{{ f.label }}</button>{% endfor %}
          </div>
        </div>
        <div class="logo-axis" data-axis="surface">
          <span class="logo-axis-label">Surface</span>
          <div class="logo-axis-options">
            {% for s in logos.surfaces %}<button type="button" class="logo-toggle" data-axis="surface" data-value="{{ s.key }}">{{ s.label }}</button>{% endfor %}
          </div>
        </div>
      </div>

      <div class="logo-picker-stage">
        <div class="logo-stage-canvas" id="logoStageCanvas">
          <img id="logoStageImg" src="" alt="">
        </div>
        <div class="logo-stage-meta">
          <div class="logo-stage-caption" id="logoStageCaption"></div>
          <div class="logo-stage-aspect" id="logoStageAspect"></div>
          <div class="logo-stage-downloads">
            <a class="logo-dl-primary" id="logoStageSvg" href="#">Download SVG</a>
            <div class="logo-dl-pngs" id="logoStagePngs"></div>
          </div>
        </div>
      </div>
    </div>

    <details class="logo-gallery">
      <summary>All {{ logos.count }} variants</summary>
      {% for m in logos.marks %}
        <h3 class="logo-gallery-heading">{{ m.label }}</h3>
        <div class="logo-gallery-grid">
          {% for v in logos.variants %}{% if v.mark == m.key %}
            <figure class="logo-gallery-item">
              <div class="logo-tile{% if v.checker %} checker-{{ v.checker }}{% endif %}">
                <img src="{{ ('/assets/raster/' + v.name + '-512.png') | url }}" alt="{{ v.caption }}" loading="lazy" decoding="async">
              </div>
              <figcaption>{{ v.surfaceLabel }} · {{ v.frameLabel }}</figcaption>
              <div class="action-bar">
                <a href="{{ ('/assets/logos/' + v.svg) | url }}">SVG →</a>
                <a href="{{ ('/assets/raster/' + (v.pngs | last)) | url }}">PNG →</a>
              </div>
            </figure>
          {% endif %}{% endfor %}
        </div>
      {% endfor %}
    </details>
  </div>
</section>

<section id="colors">
  <div class="container">
    <div class="eyebrow">Colors</div>
    <h2>Color Palette</h2>

    <h3>Primary</h3>
    {% set colors = palette.primary.slice(0, 5) %}
    {% include "partials/swatches.njk" %}
    <div style="margin-top: 16px;">
      {% set colors = palette.primary.slice(5) %}
      {% include "partials/swatches.njk" %}
    </div>

    <h3>Secondary</h3>
    {% set colors = palette.secondary %}
    {% set columns = 2 %}
    {% include "partials/swatches.njk" %}
    {% set columns = null %}

    <h3>Usage Rules</h3>
    <ul class="rules-list">
      <li>On cream: text headings, body copy, terracotta accents</li>
      <li>On black: light headings, muted copy, terracotta/accent accents</li>
      <li>Never pure #000 or #fff</li>
      <li>Max 2 accent colors per asset</li>
    </ul>
  </div>
</section>

