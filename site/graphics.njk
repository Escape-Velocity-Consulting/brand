---
layout: base.njk
title: Graphics
permalink: /graphics/
navSlug: graphics
parentSlug: templates
subtitle: "Social assets, banners, and graphic templates."
---

{% import "partials/params-table.njk" as pt %}

<section>
  <div class="container">
    <div class="eyebrow">Social</div>
    <h2>Social Assets</h2>
    {% for s in social %}
      <div style="margin-top: 32px;">
        <h3 style="margin-top: 0;">{{ s.title }}</h3>
        {% if s.rasterUrl %}
          <img class="preview-img" src="{{ s.rasterUrl | url }}" alt="{{ s.title }} — {{ s.size }}" style="max-width: 100%;">
        {% else %}
          <div style="background:#eee;border-radius:8px;padding:40px;text-align:center;color:#999;font-size:14px;">Run npm run build:assets to generate {{ s.slug }}.png</div>
        {% endif %}
        <div class="preview-caption">{{ s.title }}{% if s.size %} — {{ s.size }}{% endif %} — brand/templates/social/{{ s.slug }}.html</div>
        <div class="action-bar">
          <a href="{{ s.templateUrl }}" target="_blank">View template →</a>
          {% if s.rasterUrl %}<a href="{{ s.rasterUrl | url }}">Download PNG →</a>{% endif %}
        </div>
        {% if s.cmd %}<pre><code>{{ s.cmd }}</code></pre>{% endif %}
        <h4 class="params-heading">Parameters</h4>
        {{ pt.render(tooling.paramsByKey[s.slug]) }}
      </div>
    {% endfor %}
  </div>
</section>

<section>
  <div class="container">
    <div class="eyebrow">QR</div>
    <h2>QR Codes</h2>
    <p style="font-size: 14px; color: var(--color-body); margin-top: 8px; max-width: 60ch;">
      All four encode <a href="https://escapevelocity.consulting/hi/" target="_blank">escapevelocity.consulting/hi/</a> (the digital business card).
      Cream variants match the brand background; transparent variants drop onto any surface (slides, dark documents, print).
      The logo tile keeps a cream quiet-zone plate so it stays scannable on either background.
    </p>

    <div style="display: flex; flex-wrap: wrap; gap: 24px; margin-top: 24px;">
      {% set qrVariants = [
        { file: "qr-hi.png", label: "Cream + logo", note: "Canonical" },
        { file: "qr-hi-plain.png", label: "Cream, no logo", note: "" },
        { file: "qr-hi-transparent.png", label: "Transparent + logo", note: "" },
        { file: "qr-hi-transparent-plain.png", label: "Transparent, no logo", note: "" }
      ] %}
      {% for q in qrVariants %}
        <div style="width: 200px;">
          <div style="background-image: linear-gradient(45deg, #e8e8e8 25%, transparent 25%), linear-gradient(-45deg, #e8e8e8 25%, transparent 25%), linear-gradient(45deg, transparent 75%, #e8e8e8 75%), linear-gradient(-45deg, transparent 75%, #e8e8e8 75%); background-size: 16px 16px; background-position: 0 0, 0 8px, 8px -8px, -8px 0; border-radius: 8px; border: 1px solid rgba(0,0,0,0.06);">
            <img src="{{ ('/assets/qr/' + q.file) | url }}" alt="QR → /hi/ — {{ q.label }}" style="display: block; width: 100%; border-radius: 8px;">
          </div>
          <div class="preview-caption" style="margin-top: 8px;">{{ q.label }}{% if q.note %} — {{ q.note }}{% endif %}</div>
          <div class="action-bar"><a href="{{ ('/assets/qr/' + q.file) | url }}">Download PNG →</a></div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<section>
  <div class="container">
    <div class="eyebrow">Business Card</div>
    <h2>Digital Business Card</h2>

    <p style="font-size: 14px; color: var(--color-body); margin-top: 8px;">
      Live at <a href="https://escapevelocity.consulting/hi/" target="_blank">escapevelocity.consulting/hi/</a>.
      Source lives in the website repo (<code>website/hi/index.njk</code>) — not part of the brand system.
    </p>
  </div>
</section>

<section>
  <div class="container">
    <p class="footnote">Logo variants, SVG sources, and PNG downloads → <a href="{{ '/identity/#logos' | url }}">Identity — Logos</a></p>
  </div>
</section>
