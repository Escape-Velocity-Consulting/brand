---
layout: base.njk
title: Components
permalink: /components/
navSlug: components
parentSlug: identity
subtitle: "Buttons, cards, tags, dividers, and newsletter blocks."
---
{% from "partials/demo.njk" import demo %}

<section>
  <div class="container">
    <div class="eyebrow">Buttons</div>
    <h2>Button Variants</h2>

    <h3>Primary CTA</h3>
    {% call demo() %}
<div class="button-row">
  <a href="#" class="btn-primary">Erstgespräch buchen →</a>
</div>
    {% endcall %}

    <h3>Primary + Secondary (on dark)</h3>
    {% call demo() %}
<div class="dark-strip">
  <a href="#" class="btn-primary">Erstgespräch buchen →</a>
  <a href="#" class="btn-secondary">Mehr erfahren</a>
</div>
    {% endcall %}

    <h3>Newsletter CTA</h3>
    {% call demo() %}
<div class="button-row" style="margin-top: 16px;">
  <a href="#" class="btn-email">Weiterlesen →</a>
</div>
    {% endcall %}
  </div>
</section>

<section>
  <div class="container">
    <div class="eyebrow">Cards</div>
    <h2>Card Variants</h2>

    {% call demo() %}
<div class="cards-row">
  <div class="card-dark">
    <div class="badge">FLAGSHIP</div>
    <div class="card-title">Tech Upgrade</div>
    <div class="card-body">Engpass gefunden? Wir lösen ihn. Prozesse digitalisieren, Systeme verbinden, Automatisierung aufsetzen.</div>
  </div>
  <div class="card-light">
    <div class="card-title">Aha! Moment Workshop</div>
    <div class="card-body">Der Einstieg. Halber Tag, voller Durchblick: wo Ihre größten Hebel liegen.</div>
  </div>
  <div class="card-light">
    <div class="card-title">Laufende Begleitung</div>
    <div class="card-body">Zu früh für einen IT-Lead, aber zu viele Tech-Entscheidungen für nebenbei?</div>
  </div>
</div>
    {% endcall %}
  </div>
</section>

<section>
  <div class="container">
    <div class="eyebrow">Tags</div>
    <h2>Tags &amp; Badges</h2>

    <h3>Status Tags</h3>
    {% call demo() %}
<div class="tags-row">
  <span class="tag tag-geht">geht</span>
  <span class="tag tag-kommt">kommt</span>
  <span class="tag tag-tun">tun</span>
</div>
    {% endcall %}

    <h3>Badge</h3>
    {% call demo() %}
<div style="margin-top: 8px;">
  <span class="badge">FLAGSHIP</span>
</div>
    {% endcall %}
  </div>
</section>

<section>
  <div class="container">
    <div class="eyebrow">Dividers</div>
    <h2>Divider Variants</h2>

    {% call demo() %}
<div class="divider-demo">
  <div class="divider-label">Document Header Rule</div>
  <div class="divider-header-rule"></div>
</div>
    {% endcall %}
    {% call demo() %}
<div class="divider-demo">
  <div class="divider-label">Accent Bar</div>
  <div class="divider-accent-bar"></div>
</div>
    {% endcall %}
    {% call demo() %}
<div class="divider-demo">
  <div class="divider-label">Subject Line Border</div>
  <div class="divider-subject">Betreff: Testbrief</div>
</div>
    {% endcall %}
    {% call demo() %}
<div class="divider-demo">
  <div class="divider-label">Table Header Bottom</div>
  <div class="divider-table-header">Column Header</div>
</div>
    {% endcall %}
    {% call demo() %}
<div class="divider-demo">
  <div class="divider-label">Section Divider</div>
  <div class="divider-section"></div>
</div>
    {% endcall %}
    {% call demo() %}
<div class="divider-demo">
  <div class="divider-label">Newsletter Divider</div>
  <div class="divider-newsletter">Newsletter section separator</div>
</div>
    {% endcall %}
  </div>
</section>

<section>
  <div class="container">
    <div class="eyebrow">Newsletter</div>
    <h2>Newsletter Blocks</h2>

    <h3>TLDR Box</h3>
    {% call demo() %}
<div class="tldr-box">
  <div class="tldr-label">TLDR</div>
  <div class="tldr-body">Die meisten Unternehmen brauchen keinen Rundumschlag. Sie brauchen einen Aha! Moment.</div>
</div>
    {% endcall %}

    <h3>Callout / Quote Block</h3>
    {% call demo() %}
<div class="callout-block">
  <div class="callout-quote">Wer den Engpass findet, findet den Hebel.</div>
  <div class="callout-source">— Tommi Enenkel</div>
</div>
    {% endcall %}
  </div>
</section>

<section>
  <div class="container">
    <p class="footnote">Logo variants, SVG sources, and PNG downloads → <a href="{{ '/identity/foundations/#logos' | url }}">Identity — Logos</a></p>
