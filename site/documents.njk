---
layout: base.njk
title: Documents
permalink: /documents/
navSlug: documents
parentSlug: templates
---

{% import "partials/params-table.njk" as pt %}

<section>
  <div class="container">
    <div class="eyebrow">Documents</div>
    <h2>Document Templates</h2>

    <div class="previews-grid">
      {% for d in documents %}
        <div>
          <img class="preview-img" src="{{ d.previewUrl | url }}" alt="{{ d.title }} preview" onerror="this.outerHTML='<div style=&quot;background:#eee;border-radius:8px;padding:40px;text-align:center;color:#999;font-size:14px;&quot;>Run npm run build:assets to generate previews</div>'">
        </div>
      {% endfor %}
    </div>

    {% for d in documents %}
      <div class="doc-card">
        <h3>{{ d.title }}</h3>
        {% if d.blurb %}<p>{{ d.blurb }}</p>{% endif %}
        <div class="action-bar">
          <a href="https://github.com/Escape-Velocity-Consulting/brand/blob/main/templates/{{ d.slug }}.html" target="_blank">View template →</a>
          {% if d.pdfUrl %}<a href="{{ d.pdfUrl | url }}" target="_blank">Download PDF →</a>{% endif %}
        </div>
        {% if d.cmd %}<pre><code>{{ d.cmd }}</code></pre>{% endif %}
        <h4 class="params-heading">Parameters</h4>
        {{ pt.render(tooling.paramsByKey[d.slug]) }}
      </div>
    {% endfor %}
  </div>
</section>
