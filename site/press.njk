---
layout: base.njk
title: Press
permalink: /press/
navSlug: press
subtitle: "Boilerplate copy, founder bio, photos, and contact details."
---

<section>
  <div class="container">
    <div class="eyebrow">Boilerplate</div>
    <h2>Copy & bio</h2>
    <div class="prose">
      {{ press.html | safe }}
    </div>
    <p style="margin-top: 1.5rem;">
      <a class="btn btn-primary" href="{{ '/press/boilerplate.md' | url }}" download>Download boilerplate.md</a>
    </p>
  </div>
</section>

<section>
  <div class="container">
    <div class="eyebrow">Photos</div>
    <h2>Founder photos</h2>
    <div class="photo-grid">
      {% for p in press.photos %}
      <figure class="photo">
        <a href="{{ ('/press/photos/' + p.file) | url }}" download>
          <img src="{{ ('/press/photos/' + p.file) | url }}" alt="{{ p.alt }}" loading="lazy">
        </a>
        <figcaption>
          <span>{{ p.alt }}</span>
          <a href="{{ ('/press/photos/' + p.file) | url }}" download>Download</a>
        </figcaption>
      </figure>
      {% endfor %}
    </div>
    <p style="margin-top: 1rem; color: var(--color-subtle); font-size: 0.9rem;">
      Photos available for editorial use under the kit license. Higher resolution available on request.
    </p>
  </div>
</section>

<section>
  <div class="container">
    <div class="eyebrow">Full kit</div>
    <h2>Brand assets</h2>
    <p>
      Everything packaged together — including these press materials — is in the
      <a href="{{ '/download/' | url }}">Brand Kit download</a>.
    </p>
  </div>
</section>

<style>
.prose h1 { font-size: 1.75rem; margin: 1.5rem 0 0.5rem; }
.prose h2 { font-size: 1.35rem; margin: 1.5rem 0 0.5rem; }
.prose h3 { font-size: 1.1rem; margin: 1.25rem 0 0.4rem; color: var(--color-text); }
.prose hr { border: 0; border-top: 1px solid var(--color-doc-border); margin: 2rem 0; }
.prose ul { margin: 0.5rem 0 1rem 1.25rem; }
.prose li { margin-bottom: 0.25rem; }
.prose p { margin: 0.5rem 0 1rem; }
.prose a { color: var(--color-terracotta); }
.prose code { font-family: var(--font-mono); font-size: 0.9em; }

.photo-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-top: 1rem;
}
.photo {
  margin: 0;
  border: 1px solid var(--color-doc-border);
  border-radius: 8px;
  overflow: hidden;
  background: white;
}
.photo img { display: block; width: 100%; height: auto; }
.photo figcaption {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0.75rem 1rem;
  font-size: 0.85rem;
  color: var(--color-subtle);
}
.photo figcaption a {
  color: var(--color-terracotta);
  font-weight: 500;
  text-decoration: none;
}
</style>
