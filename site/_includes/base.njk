<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — Escape Velocity Brand Site</title>
<link rel="stylesheet" href="{{ '/tokens.css' | url }}">
<link rel="stylesheet" href="{{ '/site.css' | url }}">
<link rel="stylesheet" href="{{ '/print.css' | url }}" media="print">
{% block head %}{% endblock %}
</head>
<body>

<div class="demo-header">
  <div class="container">
    <h1>Escape <span>Velocity</span> — Brand Site</h1>
    <p>{{ subtitle or "Visual reference for all brand tokens, components, and generated assets." }}</p>
  </div>
</div>

<nav class="demo-nav">
  <div class="container">
    {% for item in nav %}
      {%- set href = ('/' + item.slug + (('/') if item.slug else '')) | url -%}
      {%- set isActive = (item.slug == navSlug) or (item.slug == parentSlug) -%}
      <a href="{{ href }}" class="{{ 'active' if isActive }}{{ ' nav-highlight' if item.highlight }}">{{ item.label }}</a>
    {% endfor %}
  </div>
</nav>

{%- set subnav = null -%}
{%- set subnavActive = "" -%}
{%- for item in nav -%}
  {%- if item.slug == navSlug and item.children -%}
    {%- set subnav = item.children -%}
    {%- set subnavActive = "" -%}
  {%- endif -%}
  {%- if item.slug == parentSlug and item.children -%}
    {%- set subnav = item.children -%}
    {%- set subnavActive = navSlug -%}
  {%- endif -%}
{%- endfor -%}

{% if subnav %}
<nav class="demo-subnav">
  <div class="container">
    {% for child in subnav %}
      {%- set childHref = ('/' + (child.href or child.slug) + '/') | url -%}
      {%- set childActive = (child.slug == subnavActive) -%}
      <a href="{{ childHref }}"{% if childActive %} class="active"{% endif %}>{{ child.label }}</a>
    {% endfor %}
  </div>
</nav>
{% endif %}

{{ content | safe }}

<div class="tagline">Digitalisierung &amp; Prozessoptimierung</div>

<div class="brand-version" style="text-align: center; padding: 1rem 0 2rem; font-family: var(--font-mono, monospace); font-size: 0.75rem; color: var(--color-subtle);">
  brand@{{ version.sha }} · built {{ version.date }}
</div>

<script>
  // Copy button for demo blocks — see partials/demo.njk
  document.addEventListener("click", function (e) {
    var btn = e.target.closest("[data-copy]");
    if (!btn) return;
    e.preventDefault();
    var code = btn.closest("details")?.querySelector("pre code");
    if (!code || !navigator.clipboard) return;
    navigator.clipboard.writeText(code.textContent).then(function () {
      var original = btn.textContent;
      btn.textContent = "Copied!";
      btn.classList.add("copied");
      setTimeout(function () {
        btn.textContent = original;
        btn.classList.remove("copied");
      }, 1200);
    });
  });
</script>

</body>
</html>
