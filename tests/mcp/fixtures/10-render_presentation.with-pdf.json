{
  "name": "inline markdown viewer + PDF",
  "tool": "render_presentation",
  "args": {
    "markdown": "<!-- @type: title -->\n# PDF deck\n> Eyebrow\n\n===\n\n<!-- @type: content -->\n## Content\n\nBody.",
    "outputDir": "{{TMP}}/mcp-e2e-deck-pdf",
    "stem": "deck",
    "pdf": true
  },
  "expect": {
    "structured": {
      "slideCount": 2,
      "html": { "mime": "text/html", "bytes": { "min": 1000 } },
      "pdf": { "mime": "application/pdf", "bytes": { "min": 5000 } }
    },
    "files": [
      { "path": "{{structured.html.path}}", "minBytes": 1000 },
      { "path": "{{structured.pdf.path}}", "minBytes": 5000 }
    ]
  }
}
