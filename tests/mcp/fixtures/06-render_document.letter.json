{
  "name": "letter from inline markdown",
  "tool": "render_document",
  "args": {
    "type": "letter",
    "markdown": "# Testbrief\n\nDies ist ein durch das E2E-System erzeugter Testbrief.\n\nMit freundlichen Grüßen,\nTommi",
    "recipient": { "name": "Test Person", "extra_lines": ["Beispielstraße 1", "1010 Wien"] },
    "outputPath": "{{TMP}}/mcp-e2e-letter.pdf"
  },
  "expect": {
    "structured": {
      "mime": "application/pdf",
      "type": "letter",
      "bytes": { "min": 10000 }
    },
    "files": [
      { "path": "{{structured.path}}", "minBytes": 10000 }
    ]
  }
}
