{
  "name": "3-slide LinkedIn portrait carousel",
  "tool": "render_carousel",
  "args": {
    "spec": {
      "format": "linkedin-portrait",
      "slides": [
        { "template": "templates/carousel/title.html", "vars": { "EYEBROW": "E2E", "BIGNUMBER": "1" } },
        { "template": "templates/carousel/numbered-item.html", "vars": { "TITLE": "Step one" } },
        { "template": "templates/carousel/cta.html", "vars": { "CTA": "Done" } }
      ]
    },
    "outputPath": "{{TMP}}/mcp-e2e-carousel.pdf"
  },
  "expect": {
    "structured": {
      "slideCount": 3,
      "width": 1080,
      "height": 1350,
      "slides": { "isArray": true, "minLength": 3 },
      "pdf": { "bytes": { "min": 20000 }, "mime": "application/pdf" }
    },
    "files": [
      { "path": "{{structured.pdf.path}}", "minBytes": 20000 }
    ]
  }
}
