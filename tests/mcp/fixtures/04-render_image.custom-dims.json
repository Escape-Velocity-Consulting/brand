{
  "name": "custom width/height + vars",
  "tool": "render_image",
  "args": {
    "template": "templates/social/og.html",
    "type": "html",
    "width": 800,
    "height": 400,
    "vars": { "TITLE": "E2E test" },
    "outputPath": "{{TMP}}/mcp-e2e-og-custom.png"
  },
  "expect": {
    "structured": {
      "mime": "image/png",
      "width": 800,
      "height": 400,
      "bytes": { "min": 2000 }
    },
    "files": [
      { "path": "{{structured.path}}", "minBytes": 2000 }
    ]
  }
}
